{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/Images/(.*)",
      "dest": "/Images/$1"
    },
    {
      "src": "/cart",
      "dest": "/api/cart.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}